#!/bin/sh
# 10Gbps Network Stack Tuning for Airoha AN7581 (2GB RAM)
# Applied on first boot via uci-defaults

# === Network Buffer Sizes (for 10Gbps throughput) ===
cat >> /etc/sysctl.d/99-10g-tuning.conf << 'SYSCTL'
# TCP/UDP buffer sizes for 10Gbps
net.core.rmem_max = 67108864
net.core.wmem_max = 67108864
net.core.rmem_default = 1048576
net.core.wmem_default = 1048576
net.ipv4.tcp_rmem = 4096 1048576 33554432
net.ipv4.tcp_wmem = 4096 1048576 33554432
net.ipv4.udp_rmem_min = 8192
net.ipv4.udp_wmem_min = 8192

# Increase socket backlog for high-throughput
net.core.netdev_max_backlog = 50000
net.core.somaxconn = 4096

# TCP optimizations
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_max_syn_backlog = 8192
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_sack = 1
net.ipv4.tcp_window_scaling = 1
net.ipv4.tcp_mtu_probing = 1
net.ipv4.tcp_no_metrics_save = 1
net.ipv4.tcp_slow_start_after_idle = 0

# Conntrack tuning (for NPU offloading with many concurrent flows)
net.netfilter.nf_conntrack_max = 131072
net.netfilter.nf_conntrack_expect_max = 2048
net.netfilter.nf_conntrack_tcp_timeout_established = 7200

# ARP/NDP cache for large networks
net.ipv4.neigh.default.gc_thresh1 = 2048
net.ipv4.neigh.default.gc_thresh2 = 4096
net.ipv4.neigh.default.gc_thresh3 = 8192
net.ipv6.neigh.default.gc_thresh1 = 2048
net.ipv6.neigh.default.gc_thresh2 = 4096
net.ipv6.neigh.default.gc_thresh3 = 8192

# IPv6 forwarding
net.ipv6.conf.all.forwarding = 1

# Reduce TIME_WAIT sockets
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 30
SYSCTL

# Apply immediately
sysctl -p /etc/sysctl.d/99-10g-tuning.conf 2>/dev/null || true

exit 0
