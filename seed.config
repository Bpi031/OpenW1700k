# Copyright: Joel Wirāmu Pauling <aenertia@aenertia.net>
# OpenWrt Defconfig for Gemtek W1700K — Complete Gateway Image

# === Target ===
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_gemtek_w1700k=y

# === Package Manager ===
# CONFIG_USE_APK is not set

# === Kernel: BPF CO-RE + BTF ===
CONFIG_KERNEL_DEBUG_INFO=y
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set
CONFIG_KERNEL_DEBUG_INFO_BTF=y
CONFIG_DWARVES=y

# ====================================================================
# eBPF NPU OFFLOADING
# ====================================================================
CONFIG_PACKAGE_airoha-offload=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_libnetfilter-conntrack=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_bpftool=y
CONFIG_PACKAGE_xdp-tools=y
CONFIG_PACKAGE_tc-bpf=y
CONFIG_PACKAGE_kmod-sched-bpf=y
CONFIG_PACKAGE_iproute2-tc=y
# CONFIG_PACKAGE_kmod-br-netfilter is not set

# === Hardware Acceleration ===
CONFIG_PACKAGE_bridger=y
CONFIG_PACKAGE_kmod-nf-flow-table=y
# CONFIG_PACKAGE_kmod-nf-flow-table-hw is not set
CONFIG_PACKAGE_luci-app-airoha-npu=y
CONFIG_PACKAGE_airoha-en7581-eagle-firmware=y

# ====================================================================
# WI-FI 7 (MT7996 BE19000)
# ====================================================================
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_WIFI_SCRIPTS_UCODE=y
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set

# ====================================================================
# LuCI + NGINX SSL REVERSE PROXY
# ====================================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-nginx=y
CONFIG_PACKAGE_nginx-ssl=y
CONFIG_PACKAGE_nginx-ssl-util=y

# --- Core LuCI Apps ---
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-vnstat2=y
CONFIG_PACKAGE_luci-app-commands=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-acl=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-advanced-reboot=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y

# --- WiFi Roaming & Management ---
CONFIG_PACKAGE_luci-app-usteer=y
CONFIG_PACKAGE_luci-app-dawn=y
CONFIG_PACKAGE_luci-app-wifischedule=y

# ====================================================================
# SECURITY & AD BLOCKING
# ====================================================================
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_luci-app-crowdsec-firewall-bouncer=y
CONFIG_PACKAGE_crowdsec=y
CONFIG_PACKAGE_crowdsec-firewall-bouncer=y
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adblock=y

# ====================================================================
# VPN
# ====================================================================
CONFIG_PACKAGE_luci-app-tailscale-community=y
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_strongswan=y
CONFIG_PACKAGE_strongswan-swanctl=y
CONFIG_PACKAGE_luci-app-strongswan-swanctl=y

# ====================================================================
# TOR / I2P / TRANSPARENT PROXY
# ====================================================================
CONFIG_PACKAGE_tor=y
CONFIG_PACKAGE_luci-app-tor=y
CONFIG_PACKAGE_i2pd=y
CONFIG_PACKAGE_privoxy=y
CONFIG_PACKAGE_luci-app-privoxy=y
CONFIG_PACKAGE_tinyproxy=y
CONFIG_PACKAGE_redsocks=y

# ====================================================================
# DYNAMIC ROUTING (FRR)
# ====================================================================
CONFIG_PACKAGE_frr=y

# ====================================================================
# OVERLAY NETWORKS (VXLAN / GENEVE / GRE / Tunnels)
# ====================================================================
CONFIG_PACKAGE_kmod-vxlan=y
CONFIG_PACKAGE_kmod-geneve=y
CONFIG_PACKAGE_luci-proto-vxlan=y
CONFIG_PACKAGE_kmod-gre=y
CONFIG_PACKAGE_kmod-ipip=y
CONFIG_PACKAGE_luci-proto-gre=y
CONFIG_PACKAGE_kmod-iptunnel=y
CONFIG_PACKAGE_kmod-iptunnel4=y
CONFIG_PACKAGE_kmod-iptunnel6=y
CONFIG_PACKAGE_kmod-sit=y
CONFIG_PACKAGE_kmod-ip6-tunnel=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-fou=y
CONFIG_PACKAGE_kmod-l2tp=y

# ====================================================================
# RADIUS (Authentication Proxy)
# ====================================================================
CONFIG_PACKAGE_freeradius3=y
CONFIG_PACKAGE_freeradius3-utils=y

# ====================================================================
# USB OVER IP (no external USB ports on W1700K)
# ====================================================================
CONFIG_PACKAGE_usbip=y
CONFIG_PACKAGE_kmod-usbip=y
CONFIG_PACKAGE_kmod-usbip-server=y
CONFIG_PACKAGE_kmod-usbip-client=y

# ====================================================================
# NFS (v4+ Client & Server)
# ====================================================================
CONFIG_PACKAGE_nfs-kernel-server=y
CONFIG_PACKAGE_nfs-kernel-server-utils=y
CONFIG_PACKAGE_nfs-utils=y
CONFIG_PACKAGE_kmod-fs-nfs=y
CONFIG_PACKAGE_kmod-fs-nfs-v4=y
CONFIG_PACKAGE_kmod-fs-nfsd=y
CONFIG_PACKAGE_kmod-fs-nfs-common=y

# ====================================================================
# DNS DEBUG TOOLS
# ====================================================================
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_bind-host=y
CONFIG_PACKAGE_drill=y
CONFIG_PACKAGE_knot-dig=y
CONFIG_PACKAGE_whois=y
CONFIG_PACKAGE_luci-app-https-dns-proxy=y

# ====================================================================
# L2 / NETWORK MONITORING & DIAGNOSTICS
# ====================================================================
CONFIG_PACKAGE_arp-scan=y
CONFIG_PACKAGE_arp-scan-database=y
CONFIG_PACKAGE_lldpd=y
CONFIG_PACKAGE_luci-app-lldpd=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_bmon=y
CONFIG_PACKAGE_iptraf-ng=y
CONFIG_PACKAGE_wavemon=y
CONFIG_PACKAGE_darkstat=y
CONFIG_PACKAGE_ss=y
CONFIG_PACKAGE_iputils-arping=y
CONFIG_PACKAGE_iputils-ping=y
CONFIG_PACKAGE_iputils-tracepath=y
CONFIG_PACKAGE_nping=y
CONFIG_PACKAGE_iw=y

# ====================================================================
# NETWORK TESTING & PERFORMANCE
# ====================================================================
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_librespeed-go=y
CONFIG_PACKAGE_nmap=y
CONFIG_PACKAGE_socat=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_netperf=y

# ====================================================================
# L2 BRIDGING & BONDING
# ====================================================================
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-ipvlan=y
CONFIG_PACKAGE_kmod-bonding=y
CONFIG_PACKAGE_ip-bridge=y
CONFIG_PACKAGE_kmod-ebtables=y
CONFIG_PACKAGE_arptables-nft=y
CONFIG_PACKAGE_ebtables-nft=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-nat=y

# ====================================================================
# SNMP
# ====================================================================
CONFIG_PACKAGE_snmpd-ssl=y
CONFIG_PACKAGE_luci-app-snmpd=y

# ====================================================================
# COLLECTD MODULES (for luci-app-statistics)
# ====================================================================
CONFIG_PACKAGE_collectd-mod-conntrack=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-ping=y
CONFIG_PACKAGE_collectd-mod-dns=y
CONFIG_PACKAGE_collectd-mod-dhcpleases=y
CONFIG_PACKAGE_collectd-mod-tcpconns=y

# ====================================================================
# PCI/USB IDENTIFICATION & DRIVERS
# ====================================================================
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_lsof=y
CONFIG_PACKAGE_strace=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y

# ====================================================================
# FILESYSTEMS
# ====================================================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_block-mount=y

# ====================================================================
# GPS (Airoha AG3352Q on /dev/ttyS2)
# ====================================================================
CONFIG_PACKAGE_gpsd=y
CONFIG_PACKAGE_gpsd-clients=y
CONFIG_PACKAGE_chrony=y

# ====================================================================
# BLUETOOTH/ZIGBEE/THREAD (EFR32MG21 on /dev/ttyS1)
# ====================================================================
CONFIG_PACKAGE_ser2net=y
CONFIG_PACKAGE_luci-app-ser2net=y

# ====================================================================
# FILE SHARING
# ====================================================================
CONFIG_PACKAGE_luci-app-samba4=y

# ====================================================================
# DNS (full dnsmasq with DNSSEC)
# ====================================================================
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# ====================================================================
# SSL/TLS & CRYPTO
# ====================================================================
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ====================================================================
# POLICY ROUTING & MULTI-WAN
# ====================================================================
CONFIG_PACKAGE_luci-app-pbr=y
CONFIG_PACKAGE_luci-app-mwan3=y

# ====================================================================
# DEVICE UTILITIES
# ====================================================================
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_smp_util=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y
CONFIG_PACKAGE_conntrack=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_kmod-usb-storage=y

# ====================================================================
# RELAY & PROTOCOLS
# ====================================================================
CONFIG_PACKAGE_luci-proto-relay=y
